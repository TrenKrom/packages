pkgname='llama.cpp'
pkgver=9750
pkgrel=1
pkgdesc='LLM inference in C/C++'
arch=(
	'x86_64'
	'armv7h'
	'aarch64'
)
url="https://github.com/ggml-org/${pkgname}"
license=('MIT')
depends=(
	'libggml.so'
	#'libggml-base.so'
	#'libggml-rpc.so'
	#'libggml-cpu.so'
	#'libggml-vulkan.so'
	'openssl'
	'hicolor-icon-theme'
)
makedepends=(
	'git'
	'cmake'
	'ninja'
	'npm'
)
optdepends=(
	'python-numpy'
	'python-safetensors'
	'python-sentencepiece'
	'python-pytorch'
	'python-transformers'
)
provides=(
	"${pkgname}"
	)
source=(
	"${pkgname}::git+${url}.git#tag=b${pkgver}"
	"${pkgname}.svg::https://raw.githubusercontent.com/ggml-org/llama.brand/refs/heads/master/icon/icon-dark.svg"
)
sha512sums=(
	'9f4dd80fa70dc8a65847b81259b809e808c4a228b654989bd4a1eabebd0cdb1bcda920d4448b6d4fa7818ea97f99904867ec35583a82a317665a38be883f7a21'
	'5ca06448b314229d731cbc4a8ad1853991ea8d37d27a349dfc234b164155e50a4d719ef5e8c6f11366914a2c10c1c61348f8071c32fd7d0fffd11d77e2c898f7'
)

prepare() {
	mkdir -p "${srcdir}/${pkgname}/build"
	git -C "${srcdir}/${pkgname}" clean -dfx
	BUILD_NUMBER=$(git -C "${srcdir}/${pkgname}" rev-list --count HEAD)
	BUILD_COMMIT=$(git -C "${srcdir}/${pkgname}" rev-parse --short HEAD)
	ulimit -n 2048
}

build() {
	cmake -B "${srcdir}/${pkgname}/build" \
		-S "${srcdir}/${pkgname}" \
		-G 'Ninja' \
		-Wno-dev \
		-Wno-deprecated-enum-enum-conversion \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX='/usr' \
		-DCMAKE_C_COMPILER='/usr/bin/gcc' \
		-DCMAKE_CXX_COMPILER='/usr/bin/g++' \
		-DBUILD_SHARED_LIBS=ON \
		-DLLAMA_BUILD_NUMBER="${BUILD_NUMBER}" \
		-DLLAMA_BUILD_COMMIT="${BUILD_COMMIT}" \
		-DLLAMA_OPENSSL=ON \
		-DLLAMA_USE_PREBUILT_WEBUI=OFF \
		-DLLAMA_BUILD_EXAMPLES=OFF \
		-DLLAMA_BUILD_TESTS=OFF \
		-DLLAMA_USE_SYSTEM_GGML=ON
	cmake --build "${srcdir}/${pkgname}/build"
}

package() {
	DESTDIR="${pkgdir}" cmake --install "${srcdir}/${pkgname}/build"
	install -Dvm644 "${srcdir}/${pkgname}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
	#install -Dvm644 "${srcdir}/${pkgname}/media/llama1-icon-transparent.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg"
	install -Dvm644 "${srcdir}/${pkgname}.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg"
	ln -srv "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname%.cpp}.svg"
}
