pkgname='llama.cpp'
pkgver=9733
pkgrel=1
pkgdesc='LLM inference in C/C++'
arch=(
	'x86_64'
	'armv7h'
	'aarch64'
)
url="https://github.com/ggml-org/${pkgname}"
license=('MIT')
depends=(
	'libggml.so'
	#'libggml-base.so'
	#'libggml-rpc.so'
	#'libggml-cpu.so'
	#'libggml-vulkan.so'
	'openssl'
	'hicolor-icon-theme'
)
makedepends=(
	'git'
	'cmake'
	'ninja'
	'npm'
)
optdepends=(
	'python-numpy'
	'python-safetensors'
	'python-sentencepiece'
	'python-pytorch'
	'python-transformers'
)
provides=(
	"${pkgname}"
	)
source=(
	"${pkgname}::git+${url}.git#tag=b${pkgver}"
	"${pkgname}.svg::https://raw.githubusercontent.com/ggml-org/llama.brand/refs/heads/master/icon/icon-dark.svg"
)
sha512sums=(
	'7f682b8f75d99bbc8fdf6dd507e4e9d32f8f008d79f228bcca09331822e9f783efae23968dfa24b4d1f3638ce28157ffa48047d6c48252bd28e4670a82ddace0'
	'5ca06448b314229d731cbc4a8ad1853991ea8d37d27a349dfc234b164155e50a4d719ef5e8c6f11366914a2c10c1c61348f8071c32fd7d0fffd11d77e2c898f7'
)

prepare() {
	git -C "${pkgname}" clean -dfx
	BUILD_NUMBER=$(git -C "${pkgname}" rev-list --count HEAD)
	BUILD_COMMIT=$(git -C "${pkgname}" rev-parse --short HEAD)
	ulimit -n 2048
}

build() {
	cmake -B build \
		-S "${pkgname}" \
		-G Ninja \
		-W no-dev \
		-D CMAKE_BUILD_TYPE=Release \
		-D CMAKE_INSTALL_PREFIX='/usr' \
		-D CMAKE_C_COMPILER='/usr/bin/gcc' \
		-D CMAKE_CXX_COMPILER='/usr/bin/g++' \
		-D BUILD_SHARED_LIBS=ON \
		-D LLAMA_BUILD_NUMBER="${BUILD_NUMBER}" \
		-D LLAMA_BUILD_COMMIT="${BUILD_COMMIT}" \
		-D LLAMA_OPENSSL=ON \
		-D LLAMA_USE_PREBUILT_WEBUI=OFF \
		-D LLAMA_BUILD_EXAMPLES=OFF \
		-D LLAMA_BUILD_TESTS=OFF \
		-D LLAMA_USE_SYSTEM_GGML=ON
	cmake --build build
}

package() {
	DESTDIR="$pkgdir/" cmake --install build
	install -Dvm644 "${pkgname}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
	#install -Dvm644 "${pkgname}/media/llama1-icon-transparent.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg"
	install -Dvm644 "${pkgname}.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg"
	ln -srv "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname%.cpp}.svg"
}
