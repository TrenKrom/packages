pkgname='llama.cpp'
pkgver=9682
pkgrel=1
pkgdesc='LLM inference in C/C++'
arch=(
	'x86_64'
	'armv7h'
	'aarch64'
)
url="https://github.com/ggml-org/${pkgname}"
license=('MIT')
depends=(
	'libggml.so'
	#'libggml-base.so'
	#'libggml-rpc.so'
	#'libggml-cpu.so'
	#'libggml-vulkan.so'
	'openssl'
	'hicolor-icon-theme'
)
makedepends=(
	'git'
	'cmake'
	'ninja'
	'npm'
)
optdepends=(
	'python-numpy'
	'python-safetensors'
	'python-sentencepiece'
	'python-pytorch'
	'python-transformers'
)
provides=(
	"${pkgname}"
	)
source=("${pkgname}::git+${url}.git#tag=b${pkgver}")
sha512sums=('58b2b1f92367bce2a84dcf86cf8122e36c039cea039583813cf3f59b081987ee178ba1ce395dd15cdb5cae112225ec3c7a390407c1d3f9f48141c4f58cbbba88')

prepare() {
	git -C "${pkgname}" clean -dfx
	BUILD_NUMBER=$(git -C "${pkgname}" rev-list --count HEAD)
	BUILD_COMMIT=$(git -C "${pkgname}" rev-parse --short HEAD)
	ulimit -n 2048
}

build() {
	cmake -B build \
		-S "${pkgname}" \
		-G Ninja \
		-Wno-dev \
		-Wdeprecated-enum-enum-conversion \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX='/usr' \
		-DCMAKE_C_COMPILER='/usr/bin/gcc' \
		-DCMAKE_CXX_COMPILER='/usr/bin/g++' \
		-DBUILD_SHARED_LIBS=ON \
		-DLLAMA_BUILD_NUMBER="${BUILD_NUMBER}" \
		-DLLAMA_BUILD_COMMIT="${BUILD_COMMIT}" \
		-DLLAMA_OPENSSL=ON \
		-DLLAMA_USE_PREBUILT_WEBUI=OFF \
		-DLLAMA_BUILD_EXAMPLES=OFF \
		-DLLAMA_BUILD_TESTS=OFF \
		-DLLAMA_USE_SYSTEM_GGML=ON
	cmake --build build
}

package() {
	DESTDIR="$pkgdir/" cmake --install build
	install -Dvm644 "${pkgname}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
	install -Dvm644 "${pkgname}/media/llama1-icon-transparent.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg"
	ln -srv "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname%.cpp}.svg"
}
