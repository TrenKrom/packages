pkgname='ggml'
pkgver=0.15.2
pkgrel=1
pkgdesc='Tensor library for machine learning'
arch=(
	'x86_64'
	'armv7h'
	'aarch64'
)
url="https://github.com/ggml-org/${pkgname}"
license=('MIT')
depends=(
	'libgcc'
	'libstdc++'
	'vulkan-icd-loader'
	'hipblas'
)
makedepends=(
	'git'
	'cmake'
	'ninja'
	'vulkan-headers'
	'spirv-headers'
	'shaderc'
	'rocm-llvm'
)
provides=(
	"lib${pkgname}.so"
	"lib${pkgname}-base.so"
	"lib${pkgname}-rpc.so"
	"lib${pkgname}-cpu.so"
	"lib${pkgname}-vulkan.so"
	"lib${pkgname}-hip.so"
)
source=("${pkgname}::git+${url}.git#tag=v${pkgver}")
sha512sums=('42c65b9c5dd045c2f705c287ebcc32629b4ab74d42a6eac6db5a000dd9f5d97b09722d8a83097aa704edb40678558f04bcb1b6d088bd2959c81f130a813e67e1')

prepare() {
	mkdir -p "${srcdir}/${pkgname}/build"
	git -C "${srcdir}/${pkgname}" clean -dfx
	ulimit -n 2048
}

build() {
	cmake -B "${srcdir}/${pkgname}/build" \
		-S "${srcdir}/${pkgname}" \
		-G 'Ninja' \
		-Wno-dev \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX='/usr' \
		-DCMAKE_C_COMPILER='/opt/rocm/llvm/bin/clang' \
		-DCMAKE_CXX_COMPILER='/opt/rocm/llvm/bin/clang++' \
		-DBUILD_SHARED_LIBS=ON \
		-DGGML_CCACHE=OFF \
		-DGGML_ALL_WARNINGS=OFF \
		-DGGML_ALL_WARNINGS_3RD_PARTY=OFF \
		-DGGML_BUILD_EXAMPLES=OFF \
		-DGGML_BUILD_TESTS=OFF \
		-DGGML_LTO=ON \
		-DGGML_RPC=ON \
		-DGGML_VULKAN=ON \
		-DGGML_HIP=ON \
		-DAMDGPU_TARGETS='gfx1030;gfx1036' \
		-DGGML_CUDA_FA_ALL_QUANTS=ON \
		-DGGML_NATIVE=ON
	cmake --build "${srcdir}/${pkgname}/build"
}

package() {
	cmake --install "${srcdir}/${pkgname}/build" --destdir="${pkgdir}" --prefix='/usr'
	install -Dvm644 "${srcdir}/${pkgname}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
